{
  "name": "cron-converter-u2q",
  "version": "1.6.0",
  "description": "Converts cron expressions between unix and quartz formats",
  "main": "lib/index.js",
  "bin": {
    "cron-converter-u2q": "lib/cli.js"
  },
  "module": "lib/esm/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "files": [
    "lib/",
    "src/"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "test": "jest --no-watchman --coverage",
    "lint": "npx eslint src/**/*.ts --fix"
  },
  "author": "BitBundler <rahu619@gmail.com>",
  "keywords": [
    "cron",
    "unix",
    "quartz",
    "cron-expression",
    "cron-convert",
    "cron-converter",
    "scheduler",
    "aws-eventbridge",
    "azure-functions",
    "spring",
    "description",
    "human-readable",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://github.com/rahu619/cron-converter-u2q",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahu619/cron-converter-u2q.git"
  },
  "devDependencies": {
    "@types/jest": "^29.5.3",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.4.9",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "eslint": "^8.46.0",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
